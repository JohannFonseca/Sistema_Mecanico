@model Sistema_de_Taller_Mecanico_de_Citas.Model.InventarioDeRepuesto

@{
    ViewData["Title"] = "Agregar Repuesto";
}

<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 2rem;
        color: #212529;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    .form-container {
        background: rgba(255, 255, 255, 0.88);
        padding: 2.5rem 3rem;
        border-radius: 0.75rem;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
        width: 100%;
        max-width: 600px;
    }

    .form-control {
        border-radius: 0.4rem;
    }

    h1 {
        text-align: center;
        color: #FE9900;
        font-weight: bold;
        margin-bottom: 1.5rem;
    }

    .btn-success {
        min-width: 120px;
    }

    .btn-secondary {
        min-width: 120px;
    }
</style>

<div class="form-container">
    <h1>@ViewData["Title"]</h1>

    <form asp-action="Create" method="post" class="row g-3">
        <div class="col-12">
            <label asp-for="Nombre" class="form-label fw-semibold"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Precio" class="form-label fw-semibold">Precio Unitario</label>
            <input asp-for="Precio" type="number" step="1" min="0" class="form-control" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>

        <div class="col-12 d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <button type="submit" class="btn btn-success px-4">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary px-4">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

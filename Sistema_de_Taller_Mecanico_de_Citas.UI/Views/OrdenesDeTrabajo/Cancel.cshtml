@model Sistema_de_Taller_Mecanico_de_Citas.Model.OrdenDeTrabajo

@{
    ViewData["Title"] = "Cancelar Orden de Trabajo";
}

<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 2rem 0;
        color: #212529;
    }

    .content-container {
        background: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
        border-radius: 0.5rem;
        box-shadow: 0 0 15px rgba(0,0,0,0.2);
        padding: 2rem 2.5rem;
    }
</style>

<h1 class="text-center text-warning fw-bold mb-5">Cancelar Orden de Trabajo</h1>

<div class="content-container mb-4">
    <h5 class="mb-4">¿Está seguro que desea cancelar esta orden?</h5>
   
</div>

<form asp-action="Cancel" method="post" class="needs-validation content-container" novalidate>
    <input type="hidden" asp-for="Id" />

    <div class="mb-4">
        <label asp-for="MotivoDeCancelacion" class="form-label fw-semibold">Motivo de Cancelación <span class="text-danger">*</span></label>
<textarea asp-for="MotivoDeCancelacion" class="form-control" rows="4"></textarea>
        <div class="invalid-feedback">
            Por favor, ingrese el motivo de cancelación.
        </div>
        <span asp-validation-for="MotivoDeCancelacion" class="text-danger"></span>
    </div>

    <div class="d-flex gap-3">
        <button type="submit" class="btn btn-warning flex-grow-1 fw-semibold">Confirmar Cancelación</button>
        <a asp-action="Index" class="btn btn-secondary flex-grow-1 fw-semibold text-center">Volver</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}

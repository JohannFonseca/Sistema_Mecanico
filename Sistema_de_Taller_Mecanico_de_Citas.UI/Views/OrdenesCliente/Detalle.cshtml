@model Sistema_de_Taller_Mecanico_de_Citas.Model.OrdenDeTrabajo

@{
    ViewData["Title"] = "Detalle Orden";
    var repuestos = ViewBag.Repuestos as List<Sistema_de_Taller_Mecanico_de_Citas.Model.OrdenRepuesto> ?? new();
    var servicios = ViewBag.Servicios as List<Sistema_de_Taller_Mecanico_de_Citas.Model.OrdenServicio> ?? new();
    var totalRepuestos = (decimal)(ViewBag.TotalRepuestos ?? 0);
    var totalServicios = (decimal)(ViewBag.TotalServicios ?? 0);
    var totalGeneral = totalRepuestos + totalServicios;
}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        justify-content: flex-start;
        align-items: center;
    }



    .detalle-container {
        background: rgba(255, 255, 255, 0.88);
        padding: 1rem;
        border-radius: 1rem;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
        width: 90vw;
        max-width: 1100px;
        max-height: 90vh;
        overflow-y: auto;
    }




    h2 {
        text-align: center;
        color: #FE9900;
        font-weight: bold;
        margin-bottom: 2rem;
    }

    .accordion-button {
        font-weight: bold;
        background-color: #FE9900;
        color: white;
    }

        .accordion-button:not(.collapsed) {
            background-color: #e58900;
            color: white;
        }

    .table th, .table td {
        text-align: center;
        vertical-align: middle;
    }

    .list-group-item {
        font-size: 1.1rem;
    }

    .btn-secondary {
        display: block;
        margin: 2rem auto 0 auto;
        padding: 0.6rem 2rem;
    }

    .table {
        min-width: 1000px; 
    }


</style>

<div class="detalle-container">
    <h2>Detalle de la Orden #@Model.Id</h2>

    <div class="accordion" id="detalleOrden">

        <!-- DETALLE GENERAL -->
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingDetalle">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDetalle" aria-expanded="true" aria-controls="collapseDetalle">
                    Información del Vehículo y Mecánico
                </button>
            </h2>
            <div id="collapseDetalle" class="accordion-collapse collapse show" aria-labelledby="headingDetalle" data-bs-parent="#detalleOrden">
                <div class="accordion-body">
                    <p><strong>Estado:</strong> @Model.EstadoTexto</p>
                    <p><strong>Tipo de Vehículo:</strong> @Model.TipoDeVehiculoTexto</p>
                    <p><strong>Marca:</strong> @Model.Marca</p>
                    <p><strong>Modelo:</strong> @Model.Modelo</p>
                    <p><strong>Tipo de Combustión:</strong> @Model.TipoDeCombustionInterna</p>
                    <p><strong>Año de Fabricación:</strong> @Model.AñoDeFabricacion</p>
                    <p><strong>Descripción del Problema:</strong> @Model.DescripcionDelProblema</p>
                    <hr />
                    @if (Model.Mecanico != null)
                    {
                        <p><strong>Identificación del Mecánico:</strong> @Model.Mecanico.Identificacion</p>
                        <p><strong>Nombre del Mecánico:</strong> @Model.Mecanico.Nombre @Model.Mecanico.Apellidos</p>
                    }
                    else
                    {
                        <p class="text-warning">Mecánico aún no asignado.</p>
                    }
                </div>
            </div>
        </div>

        <!-- REPUESTOS -->
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingRepuestos">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRepuestos" aria-expanded="false" aria-controls="collapseRepuestos">
                    Repuestos Asignados
                </button>
            </h2>
            <div id="collapseRepuestos" class="accordion-collapse collapse" aria-labelledby="headingRepuestos" data-bs-parent="#detalleOrden">
                <div class="accordion-body">
                    @if (repuestos.Any())
                    {
                        <table class="table table-bordered table-striped bg-white">
                            <thead class="table-warning text-uppercase text-secondary">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Precio Unitario</th>
                                    <th>Cantidad</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in repuestos)
                                {
                                    <tr>
                                        <td>@r.Repuesto.Nombre</td>
                                        <td>₡@r.Repuesto.Precio</td>
                                        <td>@r.Cantidad</td>
                                        <td>₡@r.Total</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p>No hay repuestos asignados.</p>
                    }
                </div>
            </div>
        </div>

        <!-- SERVICIOS -->
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingServicios">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseServicios" aria-expanded="false" aria-controls="collapseServicios">
                    Servicios Aplicados
                </button>
            </h2>
            <div id="collapseServicios" class="accordion-collapse collapse" aria-labelledby="headingServicios" data-bs-parent="#detalleOrden">
                <div class="accordion-body">
                    @if (servicios.Any())
                    {
                        <table class="table table-bordered table-striped bg-white">
                            <thead class="table-warning text-uppercase text-secondary">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Precio</th>
                                    <th>Cantidad</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in servicios)
                                {
                                    <tr>
                                        <td>@s.Servicio.Nombre</td>
                                        <td>₡@s.Servicio.Precio</td>
                                        <td>@s.Cantidad</td>
                                        <td>₡@s.Total</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p>No hay servicios aplicados.</p>
                    }
                </div>
            </div>
        </div>

        <!-- TOTALES -->
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingTotales">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTotales" aria-expanded="false" aria-controls="collapseTotales">
                    Totales
                </button>
            </h2>
            <div id="collapseTotales" class="accordion-collapse collapse" aria-labelledby="headingTotales" data-bs-parent="#detalleOrden">
                <div class="accordion-body">
                    <ul class="list-group">
                        <li class="list-group-item"><strong>Total De Repuestos:</strong> ₡@totalRepuestos</li>
                        <li class="list-group-item"><strong>Total De Servicios:</strong> ₡@totalServicios</li>
                        <li class="list-group-item"><strong>Total:</strong> <span class="fw-bold text-success">₡@totalGeneral</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-secondary mt-4">← Volver a mis órdenes</a>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

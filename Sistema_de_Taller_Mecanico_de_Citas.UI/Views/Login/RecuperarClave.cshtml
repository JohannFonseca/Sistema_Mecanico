@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

<style>
    :root {
        --primary-color: #7a4f01;
        --secondary-color: #c49b2c;
    }

    body, html {
        height: 100%;
        margin: 0;
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        font-family: 'Outfit', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #1a1a1a;
        background-blend-mode: overlay;
    }

    .card-recovery {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        max-width: 450px;
        width: 95%;
        padding: 3.5rem 3rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        text-align: center;
    }

    .card-recovery h2 {
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }

    .card-recovery p {
        color: #666;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-group {
        text-align: left;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-group i {
        position: absolute;
        left: 20px;
        top: 45px;
        color: var(--secondary-color);
    }

    .form-control {
        border-radius: 12px;
        padding: 0.8rem 1.2rem 0.8rem 3.2rem;
        border: 2px solid #eee;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 4px rgba(122, 79, 1, 0.1);
        outline: none;
    }

    label {
        font-weight: 700;
        margin-bottom: 0.6rem;
        color: #444;
        font-size: 0.9rem;
        text-transform: uppercase;
        padding-left: 5px;
    }

    .btn-recovery {
        width: 100%;
        padding: 1rem;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border: none;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        margin-top: 1rem;
        box-shadow: 0 8px 16px rgba(122, 79, 1, 0.3);
    }

    .btn-recovery:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(122, 79, 1, 0.4);
        color: white;
    }

    .back-link {
        margin-top: 2rem;
        display: block;
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
    }

    .back-link:hover {
        color: var(--secondary-color);
    }
</style>

<div class="card-recovery">
    <h2>Recuperar Clave</h2>
    <p>Ingresa tu nombre de usuario y te enviaremos tu clave actual por correo electrónico.</p>

    <form asp-action="RecuperarClave" method="post">
        <div class="form-group">
            <label>Usuario</label>
            <i class="fas fa-user"></i>
            <input type="text" name="usuario" class="form-control" placeholder="Tu nombre de usuario" required />
        </div>

        <button type="submit" class="btn btn-recovery">
            Enviar Contraseña <i class="fas fa-paper-plane ms-2"></i>
        </button>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-4">
                @Html.ValidationSummary(false)
            </div>
        }

        <a asp-action="Index" class="back-link">
            <i class="fas fa-arrow-left me-2"></i> Volver al Login
        </a>
    </form>
</div>

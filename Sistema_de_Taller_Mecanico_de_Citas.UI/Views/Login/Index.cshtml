@model Sistema_de_Taller_Mecanico_de_Citas.Model.Login

@{
    ViewData["Title"] = "Acceso al Sistema";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

<style>
    :root {
        --primary-color: #7a4f01;
        --secondary-color: #c49b2c;
        --bg-overlay: rgba(0, 0, 0, 0.4);
    }

    body, html {
        height: 100%;
        margin: 0;
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        font-family: 'Outfit', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #1a1a1a;
        background-blend-mode: overlay;
    }

    .card-login {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        max-width: 450px;
        width: 95%;
        padding: 3.5rem 3rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .card-login h2 {
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
    }

    .card-login p {
        color: #666;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-group {
        text-align: left;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-group i {
        position: absolute;
        left: 20px;
        top: 45px;
        color: var(--secondary-color);
    }

    .form-control {
        border-radius: 12px;
        padding: 0.8rem 1.2rem 0.8rem 3.2rem;
        border: 2px solid #eee;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
        background: #f8f9fa;
    }

    .form-control:focus {
        border-color: var(--primary-color);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(122, 79, 1, 0.1);
        outline: none;
    }

    label {
        font-weight: 700;
        margin-bottom: 0.6rem;
        color: #444;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding-left: 5px;
    }

    .btn-login {
        width: 100%;
        padding: 1rem;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border: none;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        margin-top: 1rem;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 8px 16px rgba(122, 79, 1, 0.3);
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(122, 79, 1, 0.4);
        color: white;
    }

    .links-container {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eee;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .links-container a {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .links-container a:hover {
        color: var(--secondary-color);
    }

    .alert {
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
    }

    .alert-success {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .alert-danger {
        background-color: #f8d7da;
        color: #842029;
    }
</style>

<div class="card-login">
    <h2>Bienvenido</h2>
    <p>Ingresa tus credenciales para continuar</p>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i> @TempData["Mensaje"]
        </div>
    }

    <form asp-action="Ingresar" method="post" novalidate>
        <div class="form-group">
            <label>Usuario</label>
            <i class="fas fa-user"></i>
            @Html.TextBoxFor(m => m.Usuario, new { @class = "form-control", placeholder = "Ej: jfonseca", autocomplete = "username" })
            @Html.ValidationMessageFor(m => m.Usuario, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            <i class="fas fa-lock"></i>
            @Html.PasswordFor(m => m.clave, new { @class = "form-control", placeholder = "••••••••", autocomplete = "current-password" })
            @Html.ValidationMessageFor(m => m.clave, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-login">
            Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>
        </button>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-4">
                @Html.ValidationSummary(false)
            </div>
        }

        <div class="links-container">
            <a asp-action="RecuperarClave">¿Olvidó su contraseña?</a>
            <a asp-action="CambiarClave">Cambiar mi contraseña</a>
        </div>
    </form>
</div>

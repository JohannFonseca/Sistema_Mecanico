@model List<SistemaOrdenesReparacion.Model.OrdenDeTrabajo>

@{
    ViewData["Title"] = "Órdenes en proceso";
}

<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 2rem;
        color: #212529;
    }

    .panel-scroll {
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        background: rgba(255, 255, 255, 0.9);
        padding: 2rem;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
        margin-left: calc(-50vw + 50%);
        width: 100vw;
        border-radius: 0.5rem;
    }
</style>

<div class="panel-scroll">

    <h1 class="text-center text-primary fw-bold mb-4">Órdenes de Trabajo en Proceso</h1>

    <form asp-action="Index" method="get" class="row g-3 align-items-center mb-4 justify-content-center">
        <div class="col-auto">
            <label for="nombre" class="col-form-label fw-semibold">Buscar por nombre del cliente:</label>
        </div>
        <div class="col-auto">
            <input type="text" id="nombre" name="nombre" class="form-control"
                   placeholder="Nombre del cliente:" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary px-4">Buscar</button>
        </div>
    </form>


    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered align-middle text-center mb-0 bg-light">
            <thead class="table-info text-secondary text-uppercase">
                <tr>
                    <th>Identificación Cliente</th>
                    <th>Nombre del Cliente</th>
                    <th>Apellidos del Cliente</th>
                    <th>Identificación del Mecánico asignado</th>
                    <th>Nombre del Mecánico asignado</th>
                    <th>Apellidos del Mecánico asignado</th>
                    <th>Tipo de Vehículo</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Tipo de combustión</th>
                    <th>Año de fabricación</th>
                    <th style="min-width: 230px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var orden in Model)
                {
                    <tr>
                        <td>@(orden.Cliente?.Identificacion ?? "N/A")</td>
                        <td>@(orden.Cliente?.Nombre ?? "N/A")</td>
                        <td>@(orden.Cliente?.Apellidos ?? "N/A")</td>
                        <td>@orden.Mecanico?.Identificacion</td> 
                        <td>@(orden.Mecanico?.Nombre ?? "N/A")</td>
                        <td>@(orden.Mecanico?.Apellidos ?? "N/A")</td>
                        <td>@orden.TipoDeVehiculoTexto</td>
                        <td>@orden.Marca</td>
                        <td>@orden.Modelo</td>
                        <td>@orden.TipoDeVehiculoTexto</td>
                        <td>@orden.AñoDeFabricacion</td>
                        <td>
                            <div class="d-grid gap-2">
                                <a asp-action="AgregarRepuesto" asp-route-id="@orden.Id" class="btn btn-outline-primary btn-sm">Agregar Repuestos</a>
                                <a asp-action="VerRepuestos" asp-route-id="@orden.Id" class="btn btn-outline-secondary btn-sm">Ver Repuestos</a>
                                <a asp-action="AgregarServicio" asp-route-id="@orden.Id" class="btn btn-outline-success btn-sm">Agregar Servicios</a>
                                <a asp-action="VerServicios" asp-route-id="@orden.Id" class="btn btn-outline-info btn-sm">Ver Servicios</a>
                                <a asp-action="VerTotal" asp-route-id="@orden.Id" class="btn btn-outline-warning btn-sm">Ver Total</a>
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- Botón de regreso al menú del mecánico -->
    <div class="mt-4 text-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary px-4">
            ← Regresar al Menú del Mecánico
        </a>
    </div>


</div>

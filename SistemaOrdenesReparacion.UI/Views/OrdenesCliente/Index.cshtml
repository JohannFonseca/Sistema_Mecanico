@model IEnumerable<SistemaOrdenesReparacion.Model.OrdenDeTrabajo>

@{
    ViewData["Title"] = "Mis Órdenes";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 2rem;
        color: #212529;
    }

    .panel-scroll {
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        background: rgba(255,255,255,0.85);
        padding: 2rem;
        box-shadow: 0 0 10px rgba(0,0,0,0.15);
        margin-left: calc(-50vw + 50%);
        width: 100vw;
        border-radius: 0.5rem;
    }
</style>

<div class="panel-scroll">

    <h1 class="text-center text-warning fw-bold mb-4">Mis ordenes</h1>

    <form method="get" asp-action="Index" class="row g-3 align-items-center mb-4 justify-content-center">
        <div class="col-12 col-md-auto">
            <label for="estado" class="col-form-label fw-semibold">Filtrar por estado:</label>
        </div>
        <div class="col-12 col-sm-8 col-md-5">
            <select id="estado" name="estado" class="form-select" onchange="this.form.submit()">
                <option value="">-- Todos --</option>
                @foreach (var estado in (IEnumerable<dynamic>)ViewBag.Estados)
                {
                    string valor = estado.Valor.ToString();
                    string texto = estado.Texto.ToString();
                    bool esSeleccionado = valor == (string)ViewBag.EstadoSeleccionado;

                    if (esSeleccionado)
                    {
                        <option value="@valor" selected>@texto</option>
                    }
                    else
                    {
                        <option value="@valor">@texto</option>
                    }
                }
            </select>

        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle text-center mb-0 bg-white">
            <thead class="table-warning text-secondary text-uppercase">
                <tr>
                    <th>Estado</th>
                    <th>Tipo de Vehículo</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Tipo de Combustión</th>
                    <th>Año de Fabricación</th>
                    <th>Acciones</th> <!-- Columna nueva -->
                </tr>
            </thead>
            <tbody>
                @foreach (var orden in Model)
                {
                    <tr>
                        <td>@orden.EstadoTexto</td>
                        <td>@(orden?.TipoDeVehiculoTexto ?? orden?.TipoDeVehiculo.ToString())</td>
                        <td>@orden.Marca</td>
                        <td>@orden.Modelo</td>
                        <td>@orden.TipoDeCombustionInterna</td>
                        <td>@orden.AñoDeFabricacion</td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@orden.Id" class="btn btn-outline-info btn-sm">Detalles</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
            ← Regresar
        </a>
    </div>

</div>

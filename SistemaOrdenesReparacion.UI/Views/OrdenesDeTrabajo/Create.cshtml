@model SistemaOrdenesReparacion.Model.OrdenDeTrabajo
@using System.Globalization

<style>
  html, body {
    height: 100%;
    margin: 0;
  }
  body {
    display: flex;
    justify-content: center;
    align-items: center;
    background-image: url('/img/fondo.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    font-family: 'Segoe UI', sans-serif;
    color: black;
    overflow: hidden;
  }
  .form-container {
    background: rgba(255, 255, 255, 0.85); /* Glassmorphism base */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 20px;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    padding: 40px 40px;
    width: 100%;
    max-width: 700px;
    max-height: 90vh;
    overflow-y: auto;
    animation: fadeIn 0.6s ease-in-out;
  }

  @@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Styling Inputs to match premium design */
  .form-control, .form-select {
    border-radius: 10px;
    border: 1px solid #ced4da;
    padding: 0.75rem 1rem;
    transition: all 0.3s ease;
  }
  .form-control:focus, .form-select:focus {
    box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
    border-color: #ffc107;
  }
  .btn-warning {
    border-radius: 25px;
    padding: 10px 30px;
    transition: transform 0.2s;
  }
  .btn-warning:hover {
    transform: scale(1.05);
  }
  .btn-secondary {
    border-radius: 25px;
    padding: 10px 30px;
  }
</style>

<div class="form-container">
    <h1 class="text-center text-warning fw-bold mb-4" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.1);">Crear Orden de Trabajo</h1>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- Selección cliente -->
        <div class="mb-3">
            <label asp-for="Id_Cliente" class="form-label">Cliente</label>
            <select asp-for="Id_Cliente" class="form-select" asp-items="@(new SelectList(ViewBag.Clientes, "Id", "NombreCompleto"))" required>
                <option value="">-- Seleccione un cliente --</option>
            </select>
            <span asp-validation-for="Id_Cliente" class="text-danger"></span>
        </div>

        <!-- Fecha de registro: solo lectura -->
        <div class="mb-3">
            <label class="form-label">Fecha de Registro</label>
            <input type="text" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm")" readonly />
        </div>

        <!-- Fecha aproximada de finalización -->
        <div class="mb-3">
            <label asp-for="FechaAproximadaDeFinalizacion" class="form-label">Fecha Aproximada de Finalización</label>
            <input asp-for="FechaAproximadaDeFinalizacion" type="date" class="form-control" required />
            <span asp-validation-for="FechaAproximadaDeFinalizacion" class="text-danger"></span>
        </div>

        <!-- Estado: solo lectura -->
        <div class="mb-3">
            <label class="form-label">Estado</label>
            <input type="text" class="form-control" value="Registrado" readonly />
        </div>

        <!-- Tipo de vehículo -->
        <div class="mb-3">
            <label asp-for="TipoDeVehiculo" class="form-label">Tipo de Vehículo</label>
            <select asp-for="TipoDeVehiculo" class="form-select" asp-items="ViewBag.TiposVehiculo" required>
                <option value="">-- Seleccione tipo de vehículo --</option>
            </select>
            <span asp-validation-for="TipoDeVehiculo" class="text-danger"></span>
        </div>

        <!-- Tipo de combustión -->
        <div class="mb-3">
            <label asp-for="TipoDeCombustionInterna" class="form-label">Tipo de Combustión</label>
            <select asp-for="TipoDeCombustionInterna" class="form-select" asp-items="ViewBag.TiposCombustion" required>
                <option value="">-- Seleccione tipo de combustión --</option>
            </select>
            <span asp-validation-for="TipoDeCombustionInterna" class="text-danger"></span>
        </div>

        <!-- Marca -->
        <div class="mb-3">
            <label asp-for="Marca" class="form-label">Marca</label>
            <input asp-for="Marca" class="form-control" required />
            <span asp-validation-for="Marca" class="text-danger"></span>
        </div>

        <!-- Modelo -->
        <div class="mb-3">
            <label asp-for="Modelo" class="form-label">Modelo</label>
            <input asp-for="Modelo" class="form-control" required />
            <span asp-validation-for="Modelo" class="text-danger"></span>
        </div>

        <!-- Año de fabricación -->
        <div class="mb-3">
            <label asp-for="AñoDeFabricacion" class="form-label">Año de Fabricación</label>
            <select asp-for="AñoDeFabricacion" class="form-select" required>
                <option value="">-- Seleccione un año --</option>
                @for (int año = DateTime.Now.Year; año >= 1900; año--)
                {
                    if (Model != null && Model.AñoDeFabricacion == año)
                    {
                        <option value="@año" selected>@año</option>
                    }
                    else
                    {
                        <option value="@año">@año</option>
                    }
                }
            </select>
            <span asp-validation-for="AñoDeFabricacion" class="text-danger"></span>
        </div>

        <!-- Descripción del problema -->
        <div class="mb-3">
            <label asp-for="DescripcionDelProblema" class="form-label">Descripción del Problema</label>
            <textarea asp-for="DescripcionDelProblema" class="form-control" rows="3" required></textarea>
            <span asp-validation-for="DescripcionDelProblema" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-warning fw-bold me-2">Crear</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model IEnumerable<SistemaOrdenesReparacion.Model.InventarioDeServicios>

@{
    ViewData["Title"] = "Servicios Disponibles";
}

<style>
    body {
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 2rem;
        color: #212529;
    }

    .panel-scroll {
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        background: rgba(255,255,255,0.88);
        padding: 2rem;
        box-shadow: 0 0 10px rgba(0,0,0,0.15);
        margin-left: calc(-50vw + 50%);
        width: 100vw;
        border-radius: 0.5rem;
    }

    h1 {
        text-align: center;
        color: #FE9900;
        font-weight: bold;
        margin-bottom: 1.5rem;
    }

    .btn-warning-custom {
        background-color: #FE9900;
        border-color: #FE9900;
        color: white;
    }

        .btn-warning-custom:hover {
            background-color: #e58900;
            border-color: #e58900;
        }

    .table th, .table td {
        text-align: center;
        vertical-align: middle;
    }

    .btn-sm {
        padding: 0.3rem 0.7rem;
    }
</style>

<div class="panel-scroll">

    <h1>@ViewData["Title"]</h1>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success text-center">@TempData["Exito"]</div>
    }

    <div class="mb-3 text-end">
        <a asp-action="Create" class="btn btn-success px-4">Agregar Servicio</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle text-center bg-white">
            <thead class="table-warning text-secondary text-uppercase">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th style="min-width: 180px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.Descripcion</td>
                        <td>₡@item.Precio</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

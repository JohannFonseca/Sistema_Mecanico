@model SistemaOrdenesReparacion.Model.CambioClave

@{
    ViewData["Title"] = "Cambio de clave";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body, html {
        height: 100%;
        margin: 0;
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: rgba(0,0,0,0.3);
        background-blend-mode: overlay;
    }

    .card-change {
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        max-width: 420px;
        width: 90%;
        padding: 3rem 2.5rem 2rem 2.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        color: #333;
        text-align: center;
        position: relative;
    }

        .card-change h4 {
            margin-bottom: 1.8rem;
            font-weight: 700;
            color: #7a4f01;
            letter-spacing: 1.1px;
        }

    form {
        position: relative;
    }

    label {
        font-weight: 600;
        margin-bottom: 0.4rem;
        display: block;
        color: #444;
    }

    .form-control {
        border-radius: 50px;
        padding: 0.75rem 1.5rem;
        box-shadow: 0 4px 8px rgba(122, 79, 1, 0.15);
        border: 1.5px solid #c49b2c;
        transition: border-color 0.3s ease;
        color: #444;
        margin-bottom: 1rem;
    }

        .form-control:focus {
            border-color: #7a4f01;
            box-shadow: 0 0 8px #7a4f01;
            outline: none;
        }

    .btn-primary {
        width: 100%;
        padding: 0.75rem;
        border-radius: 50px;
        background: linear-gradient(45deg, #7a4f01, #c49b2c);
        border: none;
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
        box-shadow: 0 6px 15px rgba(122, 79, 1, 0.5);
        transition: background 0.3s ease;
        margin-top: 0.5rem;
    }

        .btn-primary:hover {
            background: linear-gradient(45deg, #c49b2c, #7a4f01);
            box-shadow: 0 8px 20px rgba(122, 79, 1, 0.7);
        }

    .alert-danger {
        margin-top: 1rem;
        font-size: 0.95rem;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(255, 69, 0, 0.2);
    }

    .alert-success {
        margin-bottom: 1rem;
        font-size: 0.95rem;
        color: #155724;
        background-color: #d4edda;
        border-color: #c3e6cb;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        box-shadow: 0 2px 10px rgba(21, 87, 36, 0.3);
    }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: block;
    }

    .volver-link {
        margin-top: 1.5rem;
        font-size: 0.95rem;
        color: #7a4f01;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: color 0.3s ease;
    }

        .volver-link:hover {
            color: #c49b2c;
            text-decoration: underline;
        }
</style>

<div class="card-change shadow-sm">
    <h4>Cambio de clave</h4>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }

    <form asp-action="CambiarClave" method="post" novalidate>
        <div>
            <label for="NombreUsuario">Nombre de usuario</label>
            @Html.TextBoxFor(m => m.NombreUsuario, new { @class = "form-control", id = "NombreUsuario", placeholder = "Ingrese su usuario" })
            @Html.ValidationMessageFor(m => m.NombreUsuario, "", new { @class = "text-danger" })
        </div>

        <div>
            <label for="ClaveActual">Clave actual</label>
            @Html.PasswordFor(m => m.ClaveActual, new { @class = "form-control", id = "ClaveActual", placeholder = "Ingrese su clave actual" })
            @Html.ValidationMessageFor(m => m.ClaveActual, "", new { @class = "text-danger" })
        </div>

        <div>
            <label for="NuevaClave">Nueva clave</label>
            @Html.PasswordFor(m => m.NuevaClave, new { @class = "form-control", id = "NuevaClave", placeholder = "Ingrese su nueva clave" })
            @Html.ValidationMessageFor(m => m.NuevaClave, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-primary">Actualizar clave</button>

        <a asp-action="Index" class="volver-link">← Volver al login</a>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                @Html.ValidationSummary(false)
            </div>
        }
    </form>
</div>

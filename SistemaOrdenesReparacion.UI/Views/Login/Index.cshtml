@model SistemaOrdenesReparacion.Model.Login

@{
    ViewData["Title"] = "Iniciar sesión";
    int rol = Model.Rol;
    var tipoNombre = rol == 1 ? "Administrador" : rol == 3 ? "Mecánico" : "Cliente";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body, html {
        height: 100%;
        margin: 0;
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: rgba(0,0,0,0.3); /* para oscurecer un poco */
        background-blend-mode: overlay;
    }

    .card-login {
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        max-width: 420px;
        width: 90%;
        padding: 3rem 2.5rem 2rem 2.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        text-align: center;
        color: #333;
        position: relative;
        overflow: hidden;
    }

        .card-login h3 {
            margin-bottom: 1.5rem;
            font-weight: 700;
            color: #7a4f01; /* naranja suave */
            letter-spacing: 1.1px;
        }

    .nav-pills {
        justify-content: center;
        margin-bottom: 1.8rem;
    }

        .nav-pills .nav-link {
            border-radius: 50px;
            padding: 0.5rem 1.4rem;
            font-weight: 600;
            color: #555;
            transition: all 0.3s ease;
            margin: 0 6px;
            border: 2px solid transparent;
        }

            .nav-pills .nav-link:hover {
                background-color: #c49b2c; /* naranja más tenue */
                color: #fff;
            }

            .nav-pills .nav-link.active {
                background-color: #7a4f01;
                color: #fff;
                border: 2px solid #c49b2c;
                box-shadow: 0 0 12px #7a4f01;
            }

    form {
        position: relative;
    }

    .form-control {
        border-radius: 50px;
        padding: 0.75rem 1.5rem;
        box-shadow: 0 4px 8px rgba(122, 79, 1, 0.15);
        border: 1.5px solid #c49b2c;
        transition: border-color 0.3s ease;
        color: #444;
    }

        .form-control:focus {
            border-color: #7a4f01;
            box-shadow: 0 0 8px #7a4f01;
            outline: none;
        }

    label {
        font-weight: 600;
        margin-bottom: 0.4rem;
        display: block;
        color: #444;
    }

    .btn-primary {
        width: 100%;
        padding: 0.75rem;
        border-radius: 50px;
        background: linear-gradient(45deg, #7a4f01, #c49b2c);
        border: none;
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
        box-shadow: 0 6px 15px rgba(122, 79, 1, 0.5);
        transition: background 0.3s ease;
    }

        .btn-primary:hover {
            background: linear-gradient(45deg, #c49b2c, #7a4f01);
            box-shadow: 0 8px 20px rgba(122, 79, 1, 0.7);
        }

    .forgot-link {
        margin-top: 1.3rem;
        font-size: 0.95rem;
        text-align: center;
    }

        .forgot-link a {
            color: #7a4f01;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

            .forgot-link a:hover {
                color: #c49b2c;
                text-decoration: underline;
            }

    .alert-danger {
        margin-top: 1rem;
        font-size: 0.95rem;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(255, 69, 0, 0.2);
    }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="card-login shadow-sm">
    <h3>Login @tipoNombre</h3>

    <nav class="nav nav-pills mb-3">
        <a class="nav-link @(rol == 2 ? "active" : "")" href="?rol=2">Cliente</a>
        <a class="nav-link @(rol == 3 ? "active" : "")" href="?rol=3">Mecánico</a>
        <a class="nav-link @(rol == 1 ? "active" : "")" href="?rol=1">Administrador</a>
    </nav>

    @if (TempData["ErrorLogin"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["ErrorLogin"]
        </div>
    }

    <form asp-action="Ingresar" method="post" novalidate>
        @Html.HiddenFor(m => m.Rol)

        <div class="mb-3">
            <label for="Usuario">Usuario</label>
            @Html.TextBoxFor(m => m.Usuario, new { @class = "form-control", id = "Usuario", placeholder = "Ingrese su usuario" })
            @Html.ValidationMessageFor(m => m.Usuario, "", new { @class = "text-danger" })
        </div>

        <div class="mb-4">
            <label for="clave">Clave</label>
            @Html.PasswordFor(m => m.clave, new { @class = "form-control", id = "clave", placeholder = "Ingrese su clave" })
            @Html.ValidationMessageFor(m => m.clave, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-primary">Ingresar</button>

        @if (rol != 1)
        {
            <div class="forgot-link">
                <a asp-controller="Login" asp-action="CambiarClave">¿Olvidó su contraseña? ¿Cambio de clave?</a>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                @Html.ValidationSummary(false)
            </div>
        }
    </form>
</div>

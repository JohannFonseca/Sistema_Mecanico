@model SistemaOrdenesReparacion.Model.OrdenDeTrabajo

@{
    ViewData["Title"] = "Detalle Orden Cancelada";
}

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        display: flex;
        justify-content: center;
        align-items: center;
        background-image: url('/img/fondo.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        font-family: 'Segoe UI', sans-serif;
        color: black;
        overflow: hidden;
    }

    .card-container {
        background-color: white;
        border-radius: 15px;
        box-shadow: 0 0 15px rgba(0,0,0,0.3);
        padding: 40px 30px;
        width: 100%;
        max-width: 700px;
        max-height: 90vh;
        overflow-y: auto;
    }
</style>

<div class="card-container">
    <h1 class="text-center text-danger fw-bold mb-4">Detalle de Orden Cancelada</h1>

    <h5 class="fw-semibold mb-3">Información del Vehículo</h5>
    <p><strong>Tipo de Vehículo:</strong> @(Model?.TipoDeVehiculoTexto ?? Model?.TipoDeVehiculo.ToString())</p>
    <p><strong>Marca:</strong> @Model.Marca</p>
    <p><strong>Modelo:</strong> @Model.Modelo</p>
    <p><strong>Tipo de Combustión:</strong> @Model.TipoDeCombustionInterna</p>
    <p><strong>Año de Fabricación:</strong> @Model.AñoDeFabricacion</p>

    <h5 class="fw-semibold mt-4 mb-3">Detalles de la Orden</h5>
    <p><strong>Descripción del problema:</strong> @Model.DescripcionDelProblema</p>
    <p><strong>Motivo de cancelación:</strong> @Model.MotivoDeCancelacion</p>

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn btn-secondary">← Volver a la lista</a>
    </div>
</div>
